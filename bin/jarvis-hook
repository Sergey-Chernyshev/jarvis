#!/bin/sh
# jarvis-hook — шим, который дёргают хуки Claude Code.
# Использование: jarvis-hook <agent> <event>
# JSON-пейлоад события приходит в stdin (так передаёт Claude Code).
#
# Контракт: ВСЕГДА выходит с кодом 0 и мгновенно.
# Демон не запущен / сокет умер / приложение снесли — молча выходим,
# чтобы осиротевший конфиг никогда не ломал и не тормозил Claude Code.

AGENT="${1:-unknown}"
EVENT="${2:-unknown}"

# Claude Code и Codex парсят stdout Stop-хука как JSON. Пустой вывод
# теперь считается ошибкой, поэтому до любых exit-путей возвращаем
# нейтральный объект: событие продолжает работать, не управляя агентом.
case "$AGENT" in claude|codex) printf '{}\n' ;; esac

# Служебные запуски claude самим Jarvis (resume-ответ, генерация заголовков)
# не должны попадать в реестр — демон сам ведёт их жизненный цикл. Нейтральный
# JSON уже напечатан выше, поэтому и этот early exit соблюдает hook-контракт.
[ -n "$JARVIS_IGNORE" ] && exit 0

# Сокет — рядом с самим хуком: он установлен как <JARVIS_DIR>/bin/jarvis-hook,
# значит демон слушает <JARVIS_DIR>/run.sock. Так хук знает свой демон по своему
# расположению (dev → ~/.jarvis-dev, prod → ~/.jarvis) и не привязан жёстко к
# ~/.jarvis. JARVIS_SOCK переопределяет явно (тесты / спец-кейсы).
SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." 2>/dev/null && pwd)
SOCK="${JARVIS_SOCK:-${SELF_DIR:-$HOME/.jarvis}/run.sock}"

# stdin может отсутствовать при ручном запуске — не виснем на cat
if [ -t 0 ]; then
  PAYLOAD='{}'
else
  PAYLOAD=$(cat 2>/dev/null)
fi
[ -n "$PAYLOAD" ] || PAYLOAD='{}'

# Демона нет — выходим тихо
[ -S "$SOCK" ] || exit 0

# Терминалы себя подписывают: TERM_PROGRAM (iTerm.app/Apple_Terminal/vscode/…),
# у JetBrains — TERMINAL_EMULATOR=JetBrains-JediTerm. Родитель хука — сам claude.
HOST_TERM="${TERM_PROGRAM:-${TERMINAL_EMULATOR:-unknown}}"
TTY=$(ps -o tty= -p "$PPID" 2>/dev/null | tr -d ' ')
[ "$TTY" = '??' ] && TTY=''

# Поля envelope приходят из окружения/argv. Экранируем кавычки и backslash,
# control whitespace заменяем пробелами; payload остаётся исходным JSON value.
json_safe() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\r\n\t' '   '
}
AGENT_JSON=$(json_safe "$AGENT")
EVENT_JSON=$(json_safe "$EVENT")
PANE_JSON=$(json_safe "${TMUX_PANE:-}")
HOST_JSON=$(json_safe "$HOST_TERM")
TTY_JSON=$(json_safe "$TTY")
case "${PPID:-}" in ''|*[!0-9]*) HOOK_PID=0 ;; *) HOOK_PID=$PPID ;; esac

printf '{"agent":"%s","event":"%s","tmux_pane":"%s","host":"%s","tty":"%s","pid":%d,"payload":%s}' \
  "$AGENT_JSON" "$EVENT_JSON" "$PANE_JSON" "$HOST_JSON" "$TTY_JSON" "$HOOK_PID" "$PAYLOAD" \
| curl -s --max-time 0.3 --unix-socket "$SOCK" \
    -X POST --data-binary @- \
    http://jarvis/event >/dev/null 2>&1 || true

exit 0
